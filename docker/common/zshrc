# dev/sim/driver 3コンテナ共通のzsh設定。各Dockerfileから ~/.zshrc としてCOPYされる。
# ホストの ~/.zshrc(dotfiles管理・prezto+p10k)と同じ体験は持ち込めないため、
# その代わりに軽量なパーツ(zsh-autosuggestions/zsh-syntax-highlighting/starship、
# いずれもapt/静的バイナリで完結・ビルドを重くしない)で近い使用感を再現する。
# ワークスペースのsourceなど各コンテナ固有の行は、この後ろに各Dockerfileがさらに追記する。

[[ $- != *i* ]] && return

# --- 履歴 ---
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt HIST_IGNORE_DUPS SHARE_HISTORY

# --- 補完(prezto相当: メニュー選択+大文字小文字を区別しないマッチ+色付き) ---
autoload -Uz compinit && compinit -C
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"

# --- 予測入力・シンタックスハイライト(apt版、フレームワークではなく単体パッケージで軽量に) ---
[ -f /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh ] && \
    source /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh
[ -f /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ] && \
    source /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# --- プロンプト(starship、Nerd Font無しでも文字化けしないASCII安全構成) ---
command -v starship >/dev/null 2>&1 && eval "$(starship init zsh)"

# --- エイリアス(~/.zshrc(ホスト)のaliases.zshを踏襲) ---
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'

# --- colcon ---
alias cb='colcon build --symlink-install'
alias cbp='colcon build --symlink-install --packages-select'

# --- ROS2(ROS_DISTROはベースイメージ側で既に設定済み) ---
[ -f "/opt/ros/${ROS_DISTRO}/setup.zsh" ] && source "/opt/ros/${ROS_DISTRO}/setup.zsh"

# --- Humble⇔Jazzy混在による既知の無害なDDS警告を間引く(issue #7) ---
# 対象: type hash警告(Jazzy側)・rcutilsエラー上書き通知ブロック(Humble側)・
#       CycloneDDSのデシリアライズ長エラー。実データへの影響は無いことを確認済み。
# `ros2 launch`/`ros2 run`は子ノードのstderrを自分のstdoutに多重化して出すため、
# この2つに限りstdout側も濾す(他のサブコマンドのstdoutはデータなので触らない)。
# ブロック削除ではなく行単位のパターン削除なのは、launchの`[node-1]`プレフィックス付きで
# 複数プロセスの行が混ざっても(interleave)安全に落とせるようにするため。
# 生ログを見たいとき(警告そのものの調査等)は: ROS2_NOFILTER=1 ros2 ...
# 詳細: docs/解説/Humble-Jazzy混在DDS警告.md
_ROS2_NOISE_SED='/>>> \[rcutils/d;/This error state is being overwritten/d;/with this new error message/d;/invalid data size, at \./d;/string data is not null-terminated/d;/rcutils_reset_error() should be called/d;/Failed to parse type hash/d;/sequence size exceeds remaining buffer/d;/^\[[^]]*\] <<<$/d;/^<<<$/d;/^\[[^]]*\] *$/d'
ros2() {
    if [[ -n "${ROS2_NOFILTER:-}" ]]; then
        command ros2 "$@"
        return
    fi
    case "${1:-}" in
        launch|run)
            command ros2 "$@" \
                > >(sed -u "$_ROS2_NOISE_SED") \
                2> >(sed -u "$_ROS2_NOISE_SED;/^ *$/d" >&2)
            ;;
        *)
            command ros2 "$@" 2> >(sed -u "$_ROS2_NOISE_SED;/^ *$/d" >&2)
            ;;
    esac
}
